---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const loopSteps = [
  {
    command: "review / edit / fix / design",
    summary: "Start a real work session.",
    detail:
      "Choose a mode, name the task, focus the file scope, and let prtr launch the model with a structured start prompt instead of an empty chat box.",
  },
  {
    command: "checkpoint",
    summary: "Save progress without breaking flow.",
    detail:
      "Add one-line notes like 'root cause confirmed' or 'tests added' so the next handoff already knows what moved forward.",
  },
  {
    command: "@gemini / @codex",
    summary: "Hand off with diff-aware context.",
    detail:
      "prtr carries the goal, file list, checkpoints, last response, and git diff since session start so model switching does not reset the work.",
  },
  {
    command: "status / sessions",
    summary: "See the live session at a glance.",
    detail:
      "Check the current goal, mode, changed-file summary, latest checkpoint, and recent session history for the repo in one quick stop.",
  },
  {
    command: "save / resume",
    summary: "Create resume points with drift warnings.",
    detail:
      "Work Capsules save branch, SHA, touched files, todos, and next actions, then warn if the repo drifted before you resume.",
  },
  {
    command: "learn",
    summary: "Protect repo vocabulary.",
    detail:
      "Teach prtr product names, flags, and domain terms so translation and prompt shaping do not flatten the language your repo depends on.",
  },
];

const demos = [
  {
    title: "Session handoff",
    description:
      "Start an edit session, save a checkpoint, hand off to another model, and inspect the current state without rebuilding context.",
    note:
      "This is the main 1.0.0 proof loop: session first, then checkpoint, then handoff, then status.",
    image: `${basePath}media/prtr-routing-history.gif`,
    alt: "Animated demonstration of a prtr session, checkpoint, handoff, and status flow.",
  },
  {
    title: "Work Capsule resume",
    description:
      "Save a restore point, come back later, and resume with repo drift awareness instead of guessing what changed in the meantime.",
    note:
      "The capsule layer makes interrupted work feel recoverable rather than fragile.",
    image: `${basePath}media/prtr-delivery-paste.gif`,
    alt: "Animated demonstration of saving and resuming a prtr Work Capsule with drift awareness.",
  },
];

const timeline = [
  {
    version: "v0.7.x",
    title: "Deep execution",
    body: "The five-worker take --deep pipeline made prtr more than a one-shot prompt wrapper.",
  },
  {
    version: "v0.8.x",
    title: "Work Capsules",
    body: "Explicit save and resume points turned continuity into a product surface instead of a manual habit.",
  },
  {
    version: "v1.0.0",
    title: "Session-first workflow",
    body: "Sessions became the front door: start focused work, checkpoint progress, hand off cleanly, and continue in the same repo later.",
  },
  {
    version: "v1.0.1",
    title: "Auto response capture",
    body: "When Claude Code or Codex exits, prtr reads the conversation log automatically. No manual paste needed — the last response is always in the next handoff.",
  },
  {
    version: "Still available",
    title: "Classic loop tools",
    body: "go, swap, take, again, inspect, and learn remain useful for advanced or compatibility-heavy workflows.",
  },
];

const routingPoints = [
  {
    label: "Session first",
    text: "The main beginner story is no longer 'send a prompt fast' but 'start a task cleanly and keep it alive.'",
  },
  {
    label: "Handoff with proof",
    text: "Diffs, checkpoints, file scope, and the latest response travel together so switching models does not mean re-briefing them.",
  },
  {
    label: "Resume with drift awareness",
    text: "Work Capsules warn when branch, SHA, or changed files no longer match the saved point, which makes returning to work safer.",
  },
  {
    label: "Memory in two layers",
    text: "learn protects repo vocabulary, while save and resume protect task continuity. That split makes the product easier to explain and use.",
  },
];
---

<BaseLayout
  title="AI Work Session Manager"
  description="prtr helps you start focused AI work sessions, checkpoint progress, hand off to another model, and resume later with drift-aware context."
>
  <main class="page-shell">
    <header class="topbar">
      <a class="brand" href="https://github.com/helloprtr/poly-prompt" aria-label="prtr on GitHub">
        <span class="brand-mark">prtr</span>
        <span class="brand-copy">poly-prompt</span>
      </a>
      <nav class="topnav" aria-label="Primary">
        <a href="#loop">Core features</a>
        <a href="#demos">Proof demos</a>
        <a href={`${basePath}docs/`}>Docs</a>
        <a href="#timeline">Timeline</a>
      </nav>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">AI Work Session Manager</p>
        <h1>Start work. Save progress. Hand off cleanly.</h1>
        <p class="hero-text">
          prtr 1.0.0 is built around work continuity. Start a focused session, keep lightweight progress notes,
          hand the task to Gemini or Codex with the right diff and context, then resume later from a Work Capsule
          without reconstructing everything by hand.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="https://github.com/helloprtr/poly-prompt#install-in-60-seconds">Install in 60 seconds</a>
          <a class="button button-secondary" href={`${basePath}docs/`}>Open docs hub</a>
          <a class="button button-tertiary" href="https://github.com/helloprtr/poly-prompt">Read the README</a>
          <a class="button button-ghost" href="https://github.com/helloprtr/poly-prompt/releases">See releases</a>
        </div>
        <ul class="signal-strip" aria-label="Product signals">
          <li>Session first</li>
          <li>Handoff with git diff</li>
          <li>Capsules plus memory</li>
        </ul>
      </div>

      <div class="hero-console">
        <div class="panel">
          <div class="panel-header">
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
            <span class="panel-title">work-session.sh</span>
          </div>
          <div class="panel-body">
            <p class="panel-caption">One session. One handoff. One clean resume point.</p>
            <pre><code>prtr edit internal/session/store.go
prtr checkpoint "store flow cleaned up"
prtr @gemini
prtr save "session-manager mid-point"
prtr resume --dry-run</code></pre>
          </div>
        </div>

        <div class="mini-grid" aria-hidden="true">
          <div class="mini-card">
            <strong>Session</strong>
            <span>goal + files + mode</span>
          </div>
          <div class="mini-card">
            <strong>Handoff</strong>
            <span>checkpoint + diff + response</span>
          </div>
          <div class="mini-card">
            <strong>Resume</strong>
            <span>capsule + drift warning</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="loop">
      <div class="section-heading">
        <p class="eyebrow">Core features</p>
        <h2>Six pieces that make 1.0.0 usable on day one</h2>
        <p>
          The product story is no longer just a fast first prompt. It is the whole chain around real work:
          start, progress, handoff, status, resume, and memory.
        </p>
      </div>

      <div class="loop-grid">
        {loopSteps.map((step) => (
          <article class="loop-card">
            <p class="command-tag">prtr {step.command}</p>
            <h3>{step.summary}</h3>
            <p>{step.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="demos">
      <div class="section-heading">
        <p class="eyebrow">See it work</p>
        <h2>Two proof loops that explain the whole product</h2>
        <p>
          One GIF shows the live session flow. The other shows how prtr helps you come back later without
          losing the thread. Together they cover the beginner story of 1.0.0.
        </p>
      </div>

      <div class="demo-stack">
        {demos.map((demo) => (
          <article class="demo-card">
            <figure class="demo-figure">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
            </figure>
            <div class="demo-copy">
              <p class="eyebrow">{demo.title}</p>
              <h3>{demo.description}</h3>
              <p>{demo.note}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section two-column">
      <div class="section-heading">
        <p class="eyebrow">Why it matters</p>
        <h2>More continuity, less manual context repair</h2>
        <p>
          prtr is strongest when people use more than one model, pause mid-task, or need to remember exactly
          what moved since the last useful checkpoint.
        </p>
      </div>

      <div class="routing-list">
        {routingPoints.map((point) => (
          <article class="routing-card">
            <h3>{point.label}</h3>
            <p>{point.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="timeline">
      <div class="section-heading">
        <p class="eyebrow">Version story</p>
        <h2>The product kept moving from prompts toward continuity</h2>
        <p>
          Each release added another part of the same story. By 1.0.0, sessions became the main entry point
          and the older loop commands became advanced or compatibility tools instead of the default teaching path.
        </p>
      </div>

      <div class="timeline">
        {timeline.map((item) => (
          <article class="timeline-item">
            <p class="timeline-version">{item.version}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section docs-bridge">
      <div class="section-heading">
        <p class="eyebrow">Docs hub</p>
        <h2>Keep the homepage fast, move deeper in one click</h2>
        <p>
          The docs hub is where installation details, command references, Korean docs, and release context stay
          organized without overloading the landing page.
        </p>
      </div>

      <div class="bridge-card">
        <div>
          <p class="eyebrow">Included in /docs</p>
          <h3>Quick start, full guides, command reference, release notes, and media context</h3>
          <p>
            Built as a separate entry point so the homepage can stay product-focused while the docs page stays
            operator-friendly.
          </p>
        </div>
        <a class="button button-primary" href={`${basePath}docs/`}>Go to docs</a>
      </div>
    </section>

    <section class="section cta-panel">
      <div class="cta-copy">
        <p class="eyebrow">Start here</p>
        <h2>Use the session path first, then add the classic loop when you need it</h2>
        <p>
          New users should learn `review`, `edit`, `fix`, `design`, `checkpoint`, `status`, and `save` first.
          After that, `go`, `swap`, `take`, and `take --deep` become much easier to place in the workflow.
        </p>
      </div>
      <div class="panel">
        <div class="panel-header">
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-title">quick-start.sh</span>
        </div>
        <div class="panel-body">
          <pre><code>brew tap helloprtr/homebrew-tap
brew install prtr
prtr doctor
prtr edit internal/app/app.go
prtr checkpoint "root cause confirmed"
prtr @codex</code></pre>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
