---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const loopSteps = [
  {
    command: "go",
    summary: "Send the first request fast.",
    detail: "Turn raw intent into a ready prompt, launch the destination app, and keep the run in local history so the next step costs less.",
  },
  {
    command: "swap",
    summary: "Resend the same request to another AI app.",
    detail: "Keep the workflow moving while comparing Claude, Codex, or Gemini without rebuilding the same context by hand.",
  },
  {
    command: "take",
    summary: "Convert an answer into the next action.",
    detail: "Use copied model output as the seed for a patch, test, summary, issue, or plan prompt instead of rewriting it from scratch.",
  },
  {
    command: "again",
    summary: "Replay the recent flow.",
    detail: "Bring the last run back with the same app and mode, then optionally edit before delivery when you want a controlled repeat loop.",
  },
  {
    command: "learn",
    summary: "Protect project terms during translation.",
    detail: "Build a repo-local memory so names, flags, and domain language stay stable across multilingual prompt generation.",
  },
  {
    command: "inspect",
    summary: "Show the assembled routing path.",
    detail: "Open the raw composition layer when you want to see how translation, template shaping, and delivery decisions were made.",
  },
];

const demos = [
  {
    title: "One proof loop",
    description: "Start in Korean, feed in test output, compare another app, and hand the answer to the next action without rebuilding context.",
    note: "This is the one scene the whole product story should keep repeating across the README, social cards, release posts, and docs.",
    image: `${basePath}media/prtr-routing-history.gif`,
    alt: "Animated demonstration of the prtr go, swap, and take workflow",
  },
];

const timeline = [
  {
    version: "v0.1.x",
    title: "Identity",
    body: "prtr became the public name and the product got a clearer shape worth building around.",
  },
  {
    version: "v0.2.x",
    title: "Template foundation",
    body: "Interactive editing, prompt-role shaping, and cross-platform delivery support made the tool more practical for real usage.",
  },
  {
    version: "v0.3.x",
    title: "Repeatable workflow",
    body: "Setup, history, take, repo context, and learn moved prtr from one-shot prompting toward a reusable working loop.",
  },
  {
    version: "v0.4.0",
    title: "Command tree",
    body: "The Cobra-based command surface made the product easier to grow, explain, and maintain as the loop became the real product story.",
  },
];

const routingPoints = [
  {
    label: "Intent plus evidence",
    text: "prtr is strongest when the request is paired with logs, stack traces, or repo context so the next AI action starts from concrete proof instead of a blank box.",
  },
  {
    label: "App-aware handoff",
    text: "The prompt is re-shaped for Claude, Codex, or Gemini instead of pretending every app wants the same wrapper.",
  },
  {
    label: "Loop, not one-shot prompting",
    text: "swap, take, learn, and inspect stay close so the answer becomes the next step instead of another dead-end prompt tab.",
  },
];
---

<BaseLayout
  title="Repeatable AI Work Loop"
  description="prtr is the command layer for AI work. Turn logs, diffs, and intent into the next AI action across Claude, Codex, and Gemini."
>
  <main class="page-shell">
    <header class="topbar">
      <a class="brand" href="https://github.com/helloprtr/poly-prompt" aria-label="prtr on GitHub">
        <span class="brand-mark">prtr</span>
        <span class="brand-copy">poly-prompt</span>
      </a>
      <nav class="topnav" aria-label="Primary">
        <a href="#loop">Core loop</a>
        <a href="#demos">Proof demo</a>
        <a href={`${basePath}docs/`}>Docs</a>
        <a href="#timeline">Timeline</a>
      </nav>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">The command layer for AI work.</p>
        <h1>Turn intent and evidence into the next AI action.</h1>
        <p class="hero-text">
          prtr turns logs, diffs, and intent into the next AI action across Claude, Codex, and Gemini. The
          first prompt matters, but the real product is the loop after it: go, swap, take, learn, and inspect.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="https://github.com/helloprtr/poly-prompt#try-it-in-60-seconds">Try the 60s path</a>
          <a class="button button-secondary" href={`${basePath}docs/`}>Open docs hub</a>
          <a class="button button-tertiary" href="https://github.com/helloprtr/poly-prompt">Read the README</a>
          <a class="button button-ghost" href="https://github.com/helloprtr/poly-prompt/releases">See releases</a>
        </div>
        <ul class="signal-strip" aria-label="Product signals">
          <li>Logs plus intent in</li>
          <li>Claude, Codex, Gemini out</li>
          <li>swap, take, learn built in</li>
        </ul>
      </div>

      <div class="hero-console">
        <div class="panel">
          <div class="panel-header">
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
            <span class="panel-title">repeatable-work-loop.sh</span>
          </div>
          <div class="panel-body">
            <p class="panel-caption">One loop. One command layer. One next action.</p>
            <pre><code>npm test 2&gt;&amp;1 | prtr go fix "왜 깨지는지 정확한 원인만 찾아줘"
prtr swap gemini
prtr take patch
prtr learn</code></pre>
          </div>
        </div>

        <div class="mini-grid" aria-hidden="true">
          <div class="mini-card">
            <strong>Proof</strong>
            <span>logs + intent + route</span>
          </div>
          <div class="mini-card">
            <strong>Loop</strong>
            <span>swap + take + compare</span>
          </div>
          <div class="mini-card">
            <strong>Memory</strong>
            <span>learn + inspect</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="loop">
      <div class="section-heading">
        <p class="eyebrow">Core loop</p>
        <h2>Six commands that make the next step cheaper</h2>
        <p>
          The first request matters, but the second and third steps are where the real cost usually appears.
          prtr keeps intent, context, and vocabulary moving forward without sending you back to prompt glue.
        </p>
      </div>

      <div class="loop-grid">
        {loopSteps.map((step) => (
          <article class="loop-card">
            <p class="command-tag">prtr {step.command}</p>
            <h3>{step.summary}</h3>
            <p>{step.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="demos">
      <div class="section-heading">
        <p class="eyebrow">See it work</p>
        <h2>One proof loop that every launch surface should reuse</h2>
        <p>
          prtr does not need three unrelated demos on the first screen. The clearest story is one workflow:
          logs into go, app comparison through swap, and the next action through take.
        </p>
      </div>

      <div class="demo-stack">
        {demos.map((demo) => (
          <article class="demo-card">
            <figure class="demo-figure">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
            </figure>
            <div class="demo-copy">
              <p class="eyebrow">{demo.title}</p>
              <h3>{demo.description}</h3>
              <p>{demo.note}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section two-column">
      <div class="section-heading">
        <p class="eyebrow">Routing explainer</p>
        <h2>More than translation, less than a black box</h2>
        <p>
          The router is there to reduce friction, not to hide decisions. It helps users start fast while
          leaving enough visibility to trust what changed between raw intent and delivery.
        </p>
      </div>

      <div class="routing-list">
        {routingPoints.map((point) => (
          <article class="routing-card">
            <h3>{point.label}</h3>
            <p>{point.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="timeline">
      <div class="section-heading">
        <p class="eyebrow">Version story</p>
        <h2>The tool kept moving toward a repeatable loop</h2>
        <p>
          The product did not grow as a bag of unrelated commands. Each release made prtr a little less
          like a one-off prompt helper and a little more like a workflow layer.
        </p>
      </div>

      <div class="timeline">
        {timeline.map((item) => (
          <article class="timeline-item">
            <p class="timeline-version">{item.version}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section docs-bridge">
      <div class="section-heading">
        <p class="eyebrow">Docs hub</p>
        <h2>Keep the landing page fast, move deeper in one click</h2>
        <p>
          The project site now separates launch messaging from operator docs. Use the docs hub when you want
          install steps, command guides, routing notes, or release history without digging through the repo.
        </p>
      </div>

      <div class="bridge-card">
        <div>
          <p class="eyebrow">Included in /docs</p>
          <h3>Quick start, usage, router guide, demo script, and release history</h3>
          <p>
            Built as a second page so the homepage stays focused on product proof while the docs page works
            as the operator-facing entry point.
          </p>
        </div>
        <a class="button button-primary" href={`${basePath}docs/`}>Go to docs</a>
      </div>
    </section>

    <section class="section cta-panel">
      <div class="cta-copy">
        <p class="eyebrow">Start here</p>
        <h2>Try it now, then unlock multilingual routing later</h2>
        <p>
          Start with the safe preview and the English fast path. Use setup and doctor when you are ready to
          turn multilingual routing and delivery automation on for daily use.
        </p>
      </div>
      <div class="panel">
        <div class="panel-header">
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-title">quick-start.sh</span>
        </div>
        <div class="panel-body">
          <pre><code>brew tap helloprtr/homebrew-tap
brew install prtr
prtr demo
prtr go "explain this error" --dry-run
prtr setup
prtr doctor</code></pre>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
