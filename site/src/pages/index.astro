---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const loopSteps = [
  {
    command: "go",
    title: "Start from intent, not prompt babysitting.",
    body: "Write in your language, pick the right mode, and let prtr build the first useful AI action with repo context attached.",
    cue: "Best for: first send, failing tests, risky PRs, feature design",
  },
  {
    command: "swap",
    title: "Compare another app without rebuilding context.",
    body: "Keep the same request and mode, then switch between Claude, Codex, and Gemini without rewriting the whole thing.",
    cue: "Best for: side-by-side model comparison",
  },
  {
    command: "take",
    title: "Turn the answer into the next action.",
    body: "Convert copied output into a patch, issue, plan, test, commit, summary, or clarification prompt before momentum dies.",
    cue: "Best for: moving from analysis to execution",
  },
  {
    command: "learn",
    title: "Save repo memory for the next run.",
    body: "Update `.prtr/termbook.toml` and `.prtr/memory.toml` so project names, guidance, and wording survive follow-up runs.",
    cue: "Best for: repeated work in the same repo",
  },
];

const scenarios = [
  {
    eyebrow: "Fix a failing test",
    title: "Send the first useful debugging prompt in one command.",
    command: `npm test 2>&1 | prtr go fix "ýÖť ŕ╣ĘýžÇŰŐöýžÇ ýáĽÝÖĽÝĽť ýŤÉýŁŞŰžî ý░żýĽäýĄś"\nprtr swap gemini\nprtr take patch`,
    notes: ["`go` pulls in the failure log", "`swap` compares another app fast", "`take patch` turns the answer into implementation work"],
  },
  {
    eyebrow: "Review a risky PR",
    title: "Keep the review thread alive instead of starting over.",
    command: `prtr go review "ýŁ┤ PRýŚÉýäť ýťäÝŚśÝĽť ŰÂÇŰÂäŰžî ýžÜýľ┤ýĄś"\nprtr swap codex\nprtr take issue`,
    notes: ["review mode stays intact", "app comparison stays cheap", "issue writing becomes a follow-up action"],
  },
  {
    eyebrow: "Design a feature",
    title: "Move from structure to plan to repo memory.",
    command: `prtr go design "ýŁ┤ ŕŞ░ŰŐą ŕÁČýí░ ýäĄŕ│äÝĽ┤ýĄś"\nprtr take plan\nprtr learn`,
    notes: ["design mode frames the first prompt", "`take plan` turns ideas into steps", "`learn` saves project language for later"],
  },
];

const proofPoints = [
  {
    title: "Why it feels faster",
    body: "You stop paying the same setup cost over and over. The first prompt, the comparison step, the follow-up action, and the repo memory all stay in one command surface.",
  },
  {
    title: "Why it feels clearer",
    body: "Mode comes before app. `fix`, `review`, `design`, and `ask` explain what kind of help you want before you worry about prompt wording.",
  },
  {
    title: "Why it feels trustworthy",
    body: "`start`, `doctor`, `platform`, and `inspect` make activation, boundaries, and route composition visible instead of hiding them in magic.",
  },
  {
    title: "Why people keep using it",
    body: "The answer is not the end. `swap`, `take`, `again`, and `learn` make the second and third step cheaper than the first.",
  },
];

const shipNow = [
  {
    label: "Available now",
    items: ["`start`", "`go`", "`swap`", "`take`", "`again`", "`learn`", "`inspect`", "`sync`", "`doctor --fix`", "`platform`", "`exec`"],
  },
  {
    label: "Alpha / planned",
    items: ["`server` is alpha", "`fanout` is planned", "`collect` is planned"],
  },
  {
    label: "Current boundaries",
    items: ["history is local-only", "full auto submit is not supported", "`--submit confirm` is macOS-only"],
  },
];

const supportSurface = [
  {
    command: "start",
    detail: "Beginner-first entry for setup, doctor, and the first send.",
  },
  {
    command: "doctor",
    detail: "Find and explain why delivery is failing before you waste time blaming the prompt.",
  },
  {
    command: "platform",
    detail: "Show launcher, paste, and submit readiness as a platform matrix.",
  },
  {
    command: "sync",
    detail: "Render canonical `.prtr` guidance into vendor-facing files.",
  },
  {
    command: "inspect",
    detail: "Explain the compiled route, config, and JSON/debug path.",
  },
  {
    command: "exec",
    detail: "Use the same routing pipeline without the visible open-copy handoff.",
  },
];

const demos = [
  {
    title: "Input to first send",
    text: "`go` takes the first request, attaches evidence, chooses the app, and gives you a useful first move without making you hand-build the prompt.",
    image: `${basePath}media/prtr-setup-doctor.gif`,
    alt: "Animated terminal demo showing prtr go creating the first useful fix prompt from a failing test.",
  },
  {
    title: "Comparison without rewrite",
    text: "`swap` proves the comparison story: same request, same mode, different app, almost zero rebuilding cost.",
    image: `${basePath}media/prtr-routing-history.gif`,
    alt: "Animated terminal demo showing prtr swap comparing another AI app without rebuilding context.",
  },
  {
    title: "Answer to action to memory",
    text: "`take` turns the first answer into implementation work, then `learn` stores repo vocabulary so the next run starts smarter.",
    image: `${basePath}media/prtr-delivery-paste.gif`,
    alt: "Animated terminal demo showing prtr take patch and prtr learn saving repo memory.",
  },
];

const timeline = [
  {
    version: "v0.6.1",
    title: "Release reliability hardening",
    body: "GitHub Releases and Homebrew updates now run on a safer workflow path with pinned tooling and fewer avoidable warnings.",
  },
  {
    version: "v0.6.0",
    title: "Continuity upgrades",
    body: "`go` suggests next steps by mode, and `learn` now updates both termbook and repo memory by default.",
  },
  {
    version: "v0.5.1",
    title: "Public surface alignment",
    body: "README, docs, site, and CLI help all tell the same `go -> swap -> take -> learn` story.",
  },
  {
    version: "v0.5.0",
    title: "Automation and headless surface",
    body: "`exec`, `server` alpha, and the next-action framing moved prtr beyond a one-shot prompt helper.",
  },
];
---

<BaseLayout
  title="AI Command Layer"
  description="prtr turns what you mean into the next AI action across Claude, Codex, and Gemini."
>
  <main class="page-shell">
    <header class="topbar">
      <a class="brand" href={basePath} aria-label="prtr home">
        <span class="brand-mark">prtr</span>
        <span class="brand-copy">AI command layer</span>
      </a>
      <nav class="topnav" aria-label="Primary">
        <a href="#what">What it is</a>
        <a href="#loop">How it works</a>
        <a href="#proof">Proof</a>
        <a href={`${basePath}docs/`}>Docs</a>
        <a href="https://github.com/helloprtr/poly-prompt/releases">Releases</a>
      </nav>
    </header>

    <section class="hero hero-home" id="what">
      <div class="hero-copy">
        <p class="eyebrow">Command layer for multilingual AI work</p>
        <h1>prtr turns what you mean into the next AI action.</h1>
        <p class="hero-text hero-lead">
          Write in your language. Route to Claude, Codex, or Gemini. Keep the loop moving with a command surface
          built for the first send, the comparison step, the next action, and repo memory.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href="#try-now">See what to run first</a>
          <a class="button button-secondary" href="#proof">See product proof</a>
          <a class="button button-tertiary" href={`${basePath}docs/`}>Open docs hub</a>
          <a class="button button-ghost" href="https://github.com/helloprtr/poly-prompt">GitHub</a>
        </div>

        <div class="hero-tags" aria-label="Key product ideas">
          <span>One intent, many AI apps</span>
          <span>Mode before app</span>
          <span>Answer to action</span>
          <span>Repo memory</span>
        </div>
      </div>

      <div class="hero-aside">
        <article class="hero-story">
          <p class="eyebrow">If you remember one thing</p>
          <h2>Not a prompt toy. Not a full agent runtime.</h2>
          <p>
            prtr sits in the middle. It takes what you mean, routes it into the right app and mode, then keeps
            the next step close so work does not stall after the first answer.
          </p>
        </article>

        <div class="hero-route">
          <div class="route-step">
            <strong>1. Start</strong>
            <span>`go` builds the first useful prompt from your own language, logs, and repo context.</span>
          </div>
          <div class="route-step">
            <strong>2. Compare</strong>
            <span>`swap` sends the same intent to another app without rebuilding context.</span>
          </div>
          <div class="route-step">
            <strong>3. Execute</strong>
            <span>`take` turns the answer into a patch, issue, plan, test, summary, or commit prompt.</span>
          </div>
          <div class="route-step">
            <strong>4. Remember</strong>
            <span>`learn` saves repo vocabulary and guidance for future runs.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-tight" id="try-now">
      <div class="section-heading">
        <p class="eyebrow">Try this first</p>
        <h2>The product in four commands</h2>
        <p>
          If you want to understand prtr fast, do not start with settings. Start with a failing test, compare
          another app, turn the answer into work, then save the repo memory.
        </p>
      </div>

      <div class="command-ribbon">
        <div class="command-ribbon-head">
          <span class="timeline-version">30-second loop</span>
          <p>From Korean intent to routed prompt to next action.</p>
        </div>
        <pre><code>npm test 2&gt;&amp;1 | prtr go fix "ýÖť ŕ╣ĘýžÇŰŐöýžÇ ýáĽÝÖĽÝĽť ýŤÉýŁŞŰžî ý░żýĽäýĄś"
prtr swap gemini
prtr take patch
prtr learn</code></pre>
      </div>
    </section>

    <section class="section" id="loop">
      <div class="section-heading">
        <p class="eyebrow">How it works</p>
        <h2>Understand the loop before you understand the settings</h2>
        <p>
          prtr is easiest to understand when you follow the order of real work: first send, compare another
          app, turn the answer into action, then save what the repo just taught you.
        </p>
      </div>

      <div class="loop-ladder">
        {loopSteps.map((step) => (
          <article class="loop-ladder-card">
            <p class="command-tag">prtr {step.command}</p>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
            <p class="loop-cue">{step.cue}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="scenarios">
      <div class="section-heading">
        <p class="eyebrow">Common workflows</p>
        <h2>Three ways users usually understand the product</h2>
        <p>
          These examples are more useful than a feature list because they show where the time savings actually
          come from in day-to-day work.
        </p>
      </div>

      <div class="scenario-grid">
        {scenarios.map((scenario) => (
          <article class="scenario-card">
            <p class="eyebrow">{scenario.eyebrow}</p>
            <h3>{scenario.title}</h3>
            <pre><code>{scenario.command}</code></pre>
            <ul class="scenario-notes">
              {scenario.notes.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="why-fast">
      <div class="section-heading">
        <p class="eyebrow">Why it feels faster</p>
        <h2>The product advantage is workflow compression</h2>
        <p>
          prtr does not win by adding one more model picker. It wins by making the second and third step cheaper
          than the first.
        </p>
      </div>

      <div class="proof-grid">
        {proofPoints.map((point) => (
          <article class="proof-card">
            <h3>{point.title}</h3>
            <p>{point.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="proof">
      <div class="section-heading">
        <p class="eyebrow">Product proof</p>
        <h2>Three demos that map to the real loop</h2>
        <p>
          Each GIF corresponds to a user question: can I start quickly, can I compare cheaply, and can I turn
          the first answer into real work without losing momentum?
        </p>
      </div>

      <div class="demo-stack">
        {demos.map((demo) => (
          <article class="demo-card">
            <figure class="demo-figure">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
            </figure>
            <div class="demo-copy">
              <p class="eyebrow">{demo.title}</p>
              <h3>{demo.text}</h3>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section status-section">
      <div class="section-heading">
        <p class="eyebrow">What ships now</p>
        <h2>What is real today, and what is not</h2>
        <p>
          A big part of the user experience is trust. The product needs to be explicit about which commands are
          available now, which surfaces are still alpha, and which boundaries are intentional.
        </p>
      </div>

      <div class="status-grid">
        {shipNow.map((group) => (
          <article class="status-card">
            <p class="timeline-version">{group.label}</p>
            <ul class="status-list">
              {group.items.map((item) => (
                <li set:html={item}></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section support-section">
      <div class="section-heading">
        <p class="eyebrow">Trust surfaces</p>
        <h2>These commands make the loop easier to trust</h2>
        <p>
          The main loop is small on purpose. These supporting surfaces exist to help people start correctly,
          inspect the route, and recover from environment failures without guessing.
        </p>
      </div>

      <div class="support-grid-list">
        {supportSurface.map((item) => (
          <article class="support-card">
            <p class="command-tag">prtr {item.command}</p>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="timeline">
      <div class="section-heading">
        <p class="eyebrow">Version story</p>
        <h2>Recent releases, in plain language</h2>
        <p>
          You should be able to read the recent release train without decoding internal project language. These
          four milestones are the current public story in order.
        </p>
      </div>

      <div class="timeline timeline-compact">
        {timeline.map((item) => (
          <article class="timeline-item">
            <p class="timeline-version">{item.version}</p>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section docs-bridge">
      <div class="bridge-card">
        <div>
          <p class="eyebrow">Go deeper</p>
          <h2>Use the docs hub when you want install steps, the full usage guide, the v0.6.1 report, or the test checklist.</h2>
          <p>
            The homepage is now optimized for quick understanding. The docs hub is where operator docs, release
            copy, reports, and deeper references live.
          </p>
        </div>
        <a class="button button-primary" href={`${basePath}docs/`}>Open docs hub</a>
      </div>
    </section>
  </main>
</BaseLayout>
