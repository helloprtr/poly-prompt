---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const guides = [
  {
    eyebrow: "Start here",
    title: "Installation guide",
    text: "Platform-specific install and update steps for macOS, Linux, and Windows.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/INSTALLATION.md",
    linkLabel: "Read INSTALLATION.md",
    keywords: ["install", "setup", "brew", "windows", "linux", "macos"],
  },
  {
    eyebrow: "Daily use",
    title: "Usage guide",
    text: "Day-to-day commands, examples, and the main loop surface around go, swap, take, again, learn, and inspect.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md",
    linkLabel: "Read USAGE.md",
    keywords: ["usage", "commands", "go", "swap", "take", "again", "learn", "inspect"],
  },
  {
    eyebrow: "Router story",
    title: "Multilingual prompt router guide",
    text: "Setup, doctor, routing mechanics, targets, roles, templates, shortcuts, history, delivery modes, and troubleshooting.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/MULTILINGUAL_PROMPT_ROUTER_GUIDE.md",
    linkLabel: "Open router guide",
    keywords: ["router", "translation", "doctor", "target", "role", "template", "history", "paste", "troubleshooting"],
  },
  {
    eyebrow: "Demo asset",
    title: "Demo script",
    text: "Narrative and commands used to explain the multilingual routing flow in demos and README GIF captures.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/MULTILINGUAL_PROMPT_ROUTER_DEMO_SCRIPT.md",
    linkLabel: "Open demo script",
    keywords: ["demo", "script", "gif", "presentation", "routing"],
  },
];

const references = [
  {
    title: "README",
    text: "High-level product framing and quick-start path for new users.",
    href: "https://github.com/helloprtr/poly-prompt#readme",
    keywords: ["overview", "readme", "intro", "quick start"],
  },
  {
    title: "Changelog",
    text: "Release-by-release product story from identity to repeatable workflow.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/CHANGELOG.md",
    keywords: ["changelog", "release", "timeline", "versions"],
  },
  {
    title: "Releases",
    text: "Installable binaries and tagged release history on GitHub.",
    href: "https://github.com/helloprtr/poly-prompt/releases",
    keywords: ["releases", "download", "binaries", "versions"],
  },
  {
    title: "Source",
    text: "Browse the repository directly when you want implementation detail or current project status.",
    href: "https://github.com/helloprtr/poly-prompt",
    keywords: ["source", "repo", "github", "code"],
  },
];

const coreLoop = [
  "go sends the first request fast.",
  "swap compares another app without rebuilding context.",
  "take turns output into the next action.",
  "again replays the recent flow.",
  "learn stabilizes project vocabulary.",
  "inspect reveals how the route was composed.",
];

const finderItems = [
  ...guides.map((guide) => ({
    section: "Guide",
    title: guide.title,
    text: guide.text,
    href: guide.href,
    linkLabel: guide.linkLabel,
    keywords: guide.keywords.join(" "),
  })),
  ...references.map((reference) => ({
    section: "Reference",
    title: reference.title,
    text: reference.text,
    href: reference.href,
    linkLabel: `Open ${reference.title.toLowerCase()}`,
    keywords: reference.keywords.join(" "),
  })),
];

const quickQueries = [
  "install",
  "go",
  "router",
  "history",
  "paste",
  "troubleshooting",
  "releases",
];

const navSections = [
  { id: "finder", label: "Finder" },
  { id: "guides", label: "Guides" },
  { id: "media", label: "Media" },
  { id: "references", label: "References" },
];
---

<BaseLayout
  title="Docs Hub"
  description="Documentation hub for prtr installation, usage, multilingual routing, demo assets, and release history."
>
  <main class="page-shell">
    <header class="topbar">
      <a class="brand" href={`${basePath}`} aria-label="prtr home">
        <span class="brand-mark">prtr</span>
        <span class="brand-copy">docs hub</span>
      </a>
      <nav class="topnav" aria-label="Primary">
        <a href={`${basePath}`}>Home</a>
        <a href="#guides">Guides</a>
        <a href="#references">References</a>
        <a href="https://github.com/helloprtr/poly-prompt">GitHub</a>
      </nav>
    </header>

    <section class="hero hero-docs">
      <div class="hero-copy">
        <p class="eyebrow">The multilingual prompt router for repeatable AI work.</p>
        <h1>Everything around the loop, in one place.</h1>
        <p class="hero-text">
          Think in your language. Move the whole loop forward. Use this page as the documentation front door
          when you need install steps, routing references, and release context in one place.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="https://github.com/helloprtr/poly-prompt/blob/main/INSTALLATION.md">Install guide</a>
          <a class="button button-secondary" href="https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md">Usage guide</a>
          <a class="button button-ghost" href={`${basePath}`}>Back to home</a>
        </div>
      </div>

      <div class="panel">
        <div class="panel-header">
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-dot"></span>
          <span class="panel-title">docs-map.md</span>
        </div>
        <div class="panel-body">
          <p class="panel-caption">From multilingual intent to routed prompt to next action.</p>
          <ul class="doc-bullets">
            {coreLoop.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section section-tight">
      <div class="dock-shell">
        <nav class="dock-links" aria-label="Docs categories">
          {navSections.map((section) => (
            <a class="dock-link" href={`#${section.id}`}>{section.label}</a>
          ))}
        </nav>
        <div class="dock-tags" aria-label="Search tags">
          {quickQueries.map((query) => (
            <button class="finder-chip dock-chip" type="button" data-query={query}>
              {query}
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="finder">
      <div class="section-heading">
        <p class="eyebrow">Quick finder</p>
        <h2>Search the docs hub by task, command, or workflow word</h2>
        <p>
          Type what you are trying to do, or use a quick query. The cards below filter instantly so the
          docs hub feels closer to a command palette than a static link list.
        </p>
      </div>

      <div class="finder-shell">
        <label class="finder-label" for="docs-search">Search docs</label>
        <input
          id="docs-search"
          class="finder-input"
          type="search"
          placeholder="Try install, router, go, history, paste, troubleshooting..."
        />
        <p class="finder-note">Shared links preserve the current search in the `?q=` URL query.</p>
        <div class="finder-chips" aria-label="Quick queries">
          {quickQueries.map((query) => (
            <button class="finder-chip" type="button" data-query={query}>
              {query}
            </button>
          ))}
        </div>

        <div class="docs-grid finder-grid" id="finder-results">
          {finderItems.map((item) => (
            <article
              class="doc-card finder-card"
              data-search={`${item.section} ${item.title} ${item.text} ${item.keywords}`.toLowerCase()}
            >
              <p class="eyebrow">{item.section}</p>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a class="doc-link" href={item.href}>{item.linkLabel}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="guides">
      <div class="section-heading">
        <p class="eyebrow">Guides</p>
        <h2>Start, learn, and route without digging</h2>
        <p>
          These are the documents most people need first when moving from evaluation into regular use.
        </p>
      </div>

      <div class="docs-grid">
        {guides.map((guide) => (
          <article class="doc-card">
            <p class="eyebrow">{guide.eyebrow}</p>
            <h3>{guide.title}</h3>
            <p>{guide.text}</p>
            <a class="doc-link" href={guide.href}>{guide.linkLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section two-column" id="media">
      <div class="section-heading">
        <p class="eyebrow">Media and proof</p>
        <h2>The same GIF evidence, now linked from the docs side too</h2>
        <p>
          The landing page sells the workflow. The docs hub helps users verify that the workflow is grounded
          in visible setup, routing, history, and delivery behavior.
        </p>
      </div>

      <div class="routing-list">
        <article class="routing-card">
          <h3>Setup plus doctor</h3>
          <p>First-run config, DeepL readiness, and diagnostic confidence before the tool enters daily use.</p>
        </article>
        <article class="routing-card">
          <h3>Routing plus history</h3>
          <p>Visible multilingual composition and recent-run reuse instead of invisible one-shot translation.</p>
        </article>
        <article class="routing-card">
          <h3>Delivery plus paste</h3>
          <p>App launch and prompt handoff as part of the workflow surface rather than an external manual step.</p>
        </article>
      </div>
    </section>

    <section class="section" id="references">
      <div class="section-heading">
        <p class="eyebrow">References</p>
        <h2>Repository links worth keeping close</h2>
        <p>
          These links connect the docs hub back to release communication, source, and the root narrative.
        </p>
      </div>

      <div class="docs-grid docs-grid-compact">
        {references.map((reference) => (
          <article class="doc-card">
            <h3>{reference.title}</h3>
            <p>{reference.text}</p>
            <a class="doc-link" href={reference.href}>Open {reference.title.toLowerCase()}</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const input = document.querySelector("#docs-search");
    const cards = Array.from(document.querySelectorAll(".finder-card"));
    const chips = Array.from(document.querySelectorAll(".finder-chip"));
    const queryParam = "q";

    const syncUrl = (query) => {
      const url = new URL(window.location.href);

      if (query) {
        url.searchParams.set(queryParam, query);
      } else {
        url.searchParams.delete(queryParam);
      }

      window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const applyQuery = (rawValue, options = {}) => {
      const { sync = true } = options;
      const query = rawValue.trim().toLowerCase();

      cards.forEach((card) => {
        const haystack = card.dataset.search || "";
        const visible = !query || haystack.includes(query);
        card.toggleAttribute("hidden", !visible);
      });

      chips.forEach((chip) => {
        const active = chip.dataset.query === query;
        chip.dataset.active = active ? "true" : "false";
      });

      if (sync) {
        syncUrl(query);
      }
    };

    input?.addEventListener("input", (event) => {
      applyQuery(event.currentTarget.value);
    });

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        if (!input) return;
        input.value = chip.dataset.query || "";
        applyQuery(input.value);
        input.focus();
      });
    });

    const initialQuery = new URL(window.location.href).searchParams.get(queryParam) || "";

    if (input) {
      input.value = initialQuery;
    }

    applyQuery(initialQuery, { sync: false });
  </script>
</BaseLayout>
