---
import BaseLayout from "../layouts/BaseLayout.astro";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const moments = [
  {
    eyebrow: "Install and start",
    title: "Set up prtr, then make the first send with confidence.",
    body: "Use the install guide first, then move into the main usage loop without guessing which command comes next.",
    links: [
      { label: "Read INSTALLATION.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/INSTALLATION.md" },
      { label: "Read USAGE.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md" },
    ],
  },
  {
    eyebrow: "Daily work",
    title: "Stay inside go, swap, take, again, learn, and inspect.",
    body: "This is the documentation slice for people who are already using prtr and want the loop to stay fast and predictable.",
    links: [
      { label: "Open README", href: "https://github.com/helloprtr/poly-prompt#readme" },
      { label: "Read USAGE.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md" },
    ],
  },
  {
    eyebrow: "QA and evaluation",
    title: "Test the full loop, score it, and judge the handoff honestly.",
    body: "Use the report, fixture, and test checklist when you want to validate speed, continuity, memory, and trust end to end.",
    links: [
      { label: "Read V0_6_1_TEST_GUIDE.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_TEST_GUIDE.md" },
      { label: "Read V0_6_1_FIXTURE_CHECKLIST.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_FIXTURE_CHECKLIST.md" },
    ],
  },
  {
    eyebrow: "Release and launch",
    title: "Ship, verify, and announce with consistent language.",
    body: "Use the release copy and launch checklist when you need GitHub Release text, Homebrew verification, and launch operations to line up.",
    links: [
      { label: "Read RELEASE_MESSAGES.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/RELEASE_MESSAGES.md" },
      { label: "Read LAUNCH_CHECKLIST.md", href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/LAUNCH_CHECKLIST.md" },
    ],
  },
];

const loopDocs = [
  {
    eyebrow: "Start",
    title: "`go` and `swap`",
    body: "Understand the first send, model comparison, and why prtr keeps the same intent alive while switching apps.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md",
    linkLabel: "Read go / swap usage",
    keywords: ["go", "swap", "fix", "review", "design", "ask", "comparison", "route"],
  },
  {
    eyebrow: "Execute",
    title: "`take` and `again`",
    body: "See how copied output becomes a patch, issue, plan, test, commit, summary, or clarification prompt without restarting the workflow.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md",
    linkLabel: "Read take / again usage",
    keywords: ["take", "again", "patch", "issue", "plan", "test", "summary"],
  },
  {
    eyebrow: "Remember",
    title: "`learn` and repo memory",
    body: "Understand how `.prtr/termbook.toml` and `.prtr/memory.toml` get built so project wording and guidance survive future runs.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_REPORT.md",
    linkLabel: "Read the repo-memory report",
    keywords: ["learn", "termbook", "memory", "repo", "guidance"],
  },
  {
    eyebrow: "Trust",
    title: "`inspect`, `doctor`, and `platform`",
    body: "Use the route and handoff surfaces to understand whether prtr can open, paste, or only preview on the current machine.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_TEST_GUIDE.md",
    linkLabel: "Read diagnostics and test guidance",
    keywords: ["inspect", "doctor", "platform", "open-copy", "iterm", "paste", "submit"],
  },
];

const operatorSurfaces = [
  {
    command: "start",
    detail: "Use when you want the first useful send without memorizing setup details.",
  },
  {
    command: "doctor",
    detail: "Use when you need a direct explanation of what is blocking launch, paste, or translation.",
  },
  {
    command: "platform",
    detail: "Use when you only care about open-copy readiness and want the short surface summary.",
  },
  {
    command: "inspect",
    detail: "Use when you want the route, config, and compiled prompt story made visible.",
  },
  {
    command: "sync",
    detail: "Use when you want canonical `.prtr` guidance rendered into vendor-facing files.",
  },
  {
    command: "exec",
    detail: "Use when you want the same routing pipeline without the visible open-copy handoff.",
  },
];

const demos = [
  {
    title: "Input to first send",
    text: "The first GIF explains how `go` compiles intent, repo evidence, and routing into one useful first move.",
    image: `${basePath}media/prtr-setup-doctor.gif`,
    alt: "Animated terminal demo showing prtr go creating the first useful prompt from a failing test.",
  },
  {
    title: "Comparison without rewrite",
    text: "The second GIF is the proof for `swap`: the same request moves to another app without rebuilding context.",
    image: `${basePath}media/prtr-routing-history.gif`,
    alt: "Animated terminal demo showing prtr swap comparing another AI app without rebuilding context.",
  },
  {
    title: "Answer to action to memory",
    text: "The third GIF shows `take` turning the answer into work, then `learn` saving repo vocabulary and guidance.",
    image: `${basePath}media/prtr-delivery-paste.gif`,
    alt: "Animated terminal demo showing prtr take patch and prtr learn saving repo memory.",
  },
];

const references = [
  {
    title: "PRD v1",
    text: "The product definition and roadmap framing behind the command-layer surface.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/PRD_V1.md",
    keywords: ["prd", "requirements", "strategy", "roadmap"],
  },
  {
    title: "90-day backlog",
    text: "Sprint-by-sprint priorities from activation through continuity and automation readiness.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/BACKLOG_90_DAYS.md",
    keywords: ["backlog", "roadmap", "sprints", "priorities"],
  },
  {
    title: "v0.6.1 report",
    text: "The full report covering what changed from v0.4.0 to v0.6.1 and what user experience matters now.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_REPORT.md",
    keywords: ["v0.6.1", "report", "positioning", "experience", "timeline"],
  },
  {
    title: "Demo assets",
    text: "Recording scripts, captions, and asset notes for the three GIFs used across the site and launch materials.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/DEMO_ASSETS.md",
    keywords: ["demo", "gif", "assets", "captions", "recording"],
  },
  {
    title: "Legacy router guide",
    text: "Background router framing and troubleshooting kept available without becoming the front door.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/MULTILINGUAL_PROMPT_ROUTER_GUIDE.md",
    keywords: ["router", "translation", "legacy", "history", "troubleshooting"],
  },
  {
    title: "Releases",
    text: "Tagged binaries, installable archives, and GitHub release history.",
    href: "https://github.com/helloprtr/poly-prompt/releases",
    keywords: ["releases", "download", "binaries", "versions"],
  },
];

const guides = [
  {
    eyebrow: "Install",
    title: "Installation guide",
    text: "Platform-specific install and update steps for macOS, Linux, and Windows.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/INSTALLATION.md",
    linkLabel: "Read INSTALLATION.md",
    keywords: ["install", "setup", "brew", "windows", "linux", "macos"],
  },
  {
    eyebrow: "Use",
    title: "Usage guide",
    text: "Day-to-day commands, examples, and the main loop around go, swap, take, again, learn, and inspect.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/USAGE.md",
    linkLabel: "Read USAGE.md",
    keywords: ["usage", "commands", "go", "swap", "take", "again", "learn", "inspect"],
  },
  {
    eyebrow: "Evaluate",
    title: "v0.6.1 test guide",
    text: "A-Z validation for installation, loop behavior, repo memory, release health, docs consistency, and failure handling.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/V0_6_1_TEST_GUIDE.md",
    linkLabel: "Read V0_6_1_TEST_GUIDE.md",
    keywords: ["test", "qa", "doctor", "platform", "go", "swap", "take", "learn"],
  },
  {
    eyebrow: "Ship",
    title: "Launch checklist",
    text: "Operator-facing steps for prerelease checks, tagging, Homebrew verification, site/media checks, and rollback notes.",
    href: "https://github.com/helloprtr/poly-prompt/blob/main/docs/LAUNCH_CHECKLIST.md",
    linkLabel: "Read LAUNCH_CHECKLIST.md",
    keywords: ["launch", "release", "homebrew", "verification", "rollout"],
  },
];

const finderItems = [
  ...moments.map((moment) => ({
    section: "Moment",
    title: moment.title,
    text: moment.body,
    href: moment.links[0].href,
    linkLabel: moment.links[0].label,
    keywords: `${moment.eyebrow} ${moment.links.map((item) => item.label).join(" ")}`.toLowerCase(),
  })),
  ...guides.map((guide) => ({
    section: "Guide",
    title: guide.title,
    text: guide.text,
    href: guide.href,
    linkLabel: guide.linkLabel,
    keywords: guide.keywords.join(" "),
  })),
  ...loopDocs.map((guide) => ({
    section: "Loop",
    title: guide.title,
    text: guide.body,
    href: guide.href,
    linkLabel: guide.linkLabel,
    keywords: guide.keywords.join(" "),
  })),
  ...references.map((reference) => ({
    section: "Reference",
    title: reference.title,
    text: reference.text,
    href: reference.href,
    linkLabel: `Open ${reference.title.toLowerCase()}`,
    keywords: reference.keywords.join(" "),
  })),
];

const quickQueries = [
  "install",
  "go",
  "doctor",
  "platform",
  "iterm",
  "take",
  "learn",
  "release",
  "homebrew",
];

const navSections = [
  { id: "moments", label: "Moments" },
  { id: "loop", label: "Loop docs" },
  { id: "operators", label: "Operators" },
  { id: "finder", label: "Finder" },
  { id: "references", label: "References" },
];
---

<BaseLayout
  title="Docs Hub"
  description="Docs hub for prtr setup, loop usage, diagnostics, release operations, and hands-on validation."
>
  <main class="page-shell">
    <header class="topbar">
      <a class="brand" href={`${basePath}`} aria-label="prtr home">
        <span class="brand-mark">prtr</span>
        <span class="brand-copy">docs hub</span>
      </a>
      <nav class="topnav" aria-label="Primary">
        <a href={`${basePath}`}>Home</a>
        <a href="#moments">Moments</a>
        <a href="#finder">Finder</a>
        <a href="https://github.com/helloprtr/poly-prompt">GitHub</a>
      </nav>
    </header>

    <section class="hero hero-docs">
      <div class="hero-copy">
        <p class="eyebrow">Docs for the next-action command layer</p>
        <h1>Documentation that follows the loop, not the repo tree.</h1>
        <p class="hero-text hero-lead">
          Use this page when you want to know what to open first for setup, daily use, QA, or release work.
          The same `go -> swap -> take -> learn` product story from the landing page is mirrored here as
          install, operate, validate, and ship.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#moments">Choose your moment</a>
          <a class="button button-secondary" href="#loop">See loop docs</a>
          <a class="button button-tertiary" href="#finder">Search the hub</a>
          <a class="button button-ghost" href="https://github.com/helloprtr/poly-prompt#readme">Open README</a>
        </div>
        <div class="hero-tags" aria-label="Docs promises">
          <span>Setup without digging</span>
          <span>Loop-first navigation</span>
          <span>Operator-friendly releases</span>
          <span>Real QA artifacts</span>
        </div>
      </div>

      <div class="hero-aside">
        <article class="hero-story">
          <p class="eyebrow">Read this page like this</p>
          <h2>Pick the moment you are in, then follow the matching documents.</h2>
          <p>
            New users should not start in the roadmap. Release operators should not have to dig through the
            usage guide. This hub groups docs by the job you are trying to finish.
          </p>
        </article>

        <div class="hero-route">
          <div class="route-step">
            <strong>1. Install</strong>
            <span>Get the binary or brew setup right, then confirm the first usable surface.</span>
          </div>
          <div class="route-step">
            <strong>2. Operate</strong>
            <span>Stay inside `go`, `swap`, `take`, `again`, `learn`, and `inspect` without losing the thread.</span>
          </div>
          <div class="route-step">
            <strong>3. Validate</strong>
            <span>Use the fixture, test guide, and diagnostics docs to judge speed, trust, and continuity honestly.</span>
          </div>
          <div class="route-step">
            <strong>4. Ship</strong>
            <span>Use release copy and the launch checklist when you need GitHub, Homebrew, and the site to line up.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-tight">
      <div class="command-ribbon">
        <div class="command-ribbon-head">
          <span class="timeline-version">Docs order</span>
          <p>Read in this order if you want the shortest path from install to launch confidence.</p>
        </div>
        <pre><code>INSTALLATION.md
USAGE.md
V0_6_1_TEST_GUIDE.md
RELEASE_MESSAGES.md
LAUNCH_CHECKLIST.md</code></pre>
      </div>
    </section>

    <section class="section" id="moments">
      <div class="section-heading">
        <p class="eyebrow">Choose your moment</p>
        <h2>Open the right document based on the job in front of you</h2>
        <p>
          This section is the fast path when you do not care about the whole repo. Just pick the current moment
          and start from the recommended documents.
        </p>
      </div>

      <div class="status-grid">
        {moments.map((moment) => (
          <article class="status-card">
            <p class="eyebrow">{moment.eyebrow}</p>
            <h3>{moment.title}</h3>
            <p>{moment.body}</p>
            <div class="doc-actions">
              {moment.links.map((item) => (
                <a class="doc-link" href={item.href}>{item.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="loop">
      <div class="section-heading">
        <p class="eyebrow">Loop docs</p>
        <h2>Read the docs in the same order as the product loop</h2>
        <p>
          The product is not a flat command list. The docs should not be one either. These cards keep the loop
          visible so `go`, `swap`, `take`, `again`, `learn`, and `inspect` still feel like one surface.
        </p>
      </div>

      <div class="docs-grid">
        {loopDocs.map((guide) => (
          <article class="doc-card">
            <p class="eyebrow">{guide.eyebrow}</p>
            <h3>{guide.title}</h3>
            <p>{guide.body}</p>
            <a class="doc-link" href={guide.href}>{guide.linkLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="operators">
      <div class="section-heading">
        <p class="eyebrow">Operator surfaces</p>
        <h2>Use these when you need setup, diagnostics, visibility, or non-default delivery</h2>
        <p>
          The core loop lives on top, but these commands matter whenever you need to understand the current
          machine, fix a broken handoff, or route the same pipeline through a different surface.
        </p>
      </div>

      <div class="support-grid-list">
        {operatorSurfaces.map((item) => (
          <article class="support-card">
            <span class="command-tag">{item.command}</span>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section two-column" id="media">
      <div class="section-heading">
        <p class="eyebrow">Media and proof</p>
        <h2>The same proof assets from the landing page, placed in the docs flow</h2>
        <p>
          The marketing page explains the product. The docs hub helps people verify that the story is backed by
          real setup behavior, visible comparison, and answer-to-action continuity.
        </p>
      </div>

      <div class="routing-list">
        <article class="routing-card">
          <h3>`go` is not just translation</h3>
          <p>The first send should already look like work: repo context, logs, route choice, and mode are visible.</p>
        </article>
        <article class="routing-card">
          <h3>`swap` keeps comparison cheap</h3>
          <p>The request is not rebuilt from scratch. That is the difference between a one-shot helper and a reusable loop.</p>
        </article>
        <article class="routing-card">
          <h3>`take` plus `learn` create continuity</h3>
          <p>The answer becomes the next action, then repo guidance survives into future runs instead of vanishing.</p>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="demo-stack">
        {demos.map((demo) => (
          <article class="demo-card">
            <figure class="demo-figure">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
            </figure>
            <div class="demo-copy">
              <p class="eyebrow">Workflow proof</p>
              <h3>{demo.title}</h3>
              <p>{demo.text}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="finder">
      <div class="section-heading">
        <p class="eyebrow">Quick finder</p>
        <h2>Search by command, platform problem, release task, or document name</h2>
        <p>
          Type what you are trying to do, or tap a quick query. The hub filters instantly so it behaves more
          like a lightweight command palette than a static docs list.
        </p>
      </div>

      <div class="dock-shell">
        <nav class="dock-links" aria-label="Docs categories">
          {navSections.map((section) => (
            <a class="dock-link" href={`#${section.id}`}>{section.label}</a>
          ))}
        </nav>
        <div class="dock-tags" aria-label="Search tags">
          {quickQueries.map((query) => (
            <button class="finder-chip dock-chip" type="button" data-query={query}>
              {query}
            </button>
          ))}
        </div>
      </div>

      <div class="finder-shell">
        <label class="finder-label" for="docs-search">Search docs</label>
        <input
          id="docs-search"
          class="finder-input"
          type="search"
          placeholder="Try doctor, platform, iterm, release, homebrew, learn..."
        />
        <p class="finder-note">Shared links keep the current search in the `?q=` URL query.</p>
        <div class="finder-chips" aria-label="Quick queries">
          {quickQueries.map((query) => (
            <button class="finder-chip" type="button" data-query={query}>
              {query}
            </button>
          ))}
        </div>

        <div class="docs-grid finder-grid" id="finder-results">
          {finderItems.map((item) => (
            <article
              class="doc-card finder-card"
              data-search={`${item.section} ${item.title} ${item.text} ${item.keywords}`.toLowerCase()}
            >
              <p class="eyebrow">{item.section}</p>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a class="doc-link" href={item.href}>{item.linkLabel}</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="references">
      <div class="section-heading">
        <p class="eyebrow">References</p>
        <h2>Keep the deeper product and release material close, without making it the front door</h2>
        <p>
          These references matter, but they should support the main loop instead of replacing it. Use them when
          you need deeper roadmap, reporting, demo, or release context.
        </p>
      </div>

      <div class="docs-grid docs-grid-compact">
        {references.map((reference) => (
          <article class="doc-card">
            <h3>{reference.title}</h3>
            <p>{reference.text}</p>
            <a class="doc-link" href={reference.href}>Open {reference.title.toLowerCase()}</a>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script is:inline>
    const input = document.querySelector("#docs-search");
    const cards = Array.from(document.querySelectorAll(".finder-card"));
    const chips = Array.from(document.querySelectorAll(".finder-chip"));
    const queryParam = "q";

    const syncUrl = (query) => {
      const url = new URL(window.location.href);

      if (query) {
        url.searchParams.set(queryParam, query);
      } else {
        url.searchParams.delete(queryParam);
      }

      window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
    };

    const applyQuery = (rawValue, options = {}) => {
      const { sync = true } = options;
      const query = rawValue.trim().toLowerCase();

      cards.forEach((card) => {
        const haystack = card.dataset.search || "";
        const visible = !query || haystack.includes(query);
        card.toggleAttribute("hidden", !visible);
      });

      chips.forEach((chip) => {
        const active = chip.dataset.query === query;
        chip.dataset.active = active ? "true" : "false";
      });

      if (sync) {
        syncUrl(query);
      }
    };

    input?.addEventListener("input", (event) => {
      applyQuery(event.currentTarget.value);
    });

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        if (!input) return;
        input.value = chip.dataset.query || "";
        applyQuery(input.value);
        input.focus();
      });
    });

    const initialQuery = new URL(window.location.href).searchParams.get(queryParam) || "";

    if (input) {
      input.value = initialQuery;
    }

    applyQuery(initialQuery, { sync: false });
  </script>
</BaseLayout>
